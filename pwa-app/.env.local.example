# PWA — ngrok deployment environment variables
# Copy this file to .env.local and fill in your values.
# .env.local is gitignored and never committed.

# Set this to your ngrok public URL + /api when deploying via ngrok.
# Example: VITE_API_BASE_URL=https://xxxx.ngrok-free.app/api
# Leave empty (or delete this file) for local dev — falls back to '/api'.
VITE_API_BASE_URL=https://xxxx.ngrok-free.app/api
