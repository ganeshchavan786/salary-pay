# Admin Panel — ngrok deployment environment variables
# Copy this file to .env.local and fill in your values.
# .env.local is gitignored and never committed.

# Set this to /admin/ when building for ngrok deployment.
# This makes Vite set the base path and React Router use /admin as basename.
# Leave empty (or delete this file) for local dev — defaults to '/'.
VITE_BASE_PATH=/admin/
