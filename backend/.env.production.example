# ===========================================
# PRODUCTION ENVIRONMENT CONFIGURATION
# ===========================================
# Copy this file to .env and update values
# NEVER commit .env to version control!
# ===========================================

# Database (PostgreSQL for production)
DATABASE_URL=postgresql+asyncpg://username:password@localhost:5432/face_attendance

# JWT Settings
SECRET_KEY=generate-using-python-generate_keys.py
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=480

# Encryption Key for Face Descriptors
# CRITICAL: Backup this key! Losing it = losing all face data
ENCRYPTION_KEY=generate-using-python-generate_keys.py

# CORS - Add your production domains
CORS_ORIGINS=https://attendance.yourdomain.com,https://admin.yourdomain.com

# App Settings
APP_NAME=Face Attendance API
DEBUG=False

# Server Settings
HOST=0.0.0.0
PORT=8000
WORKERS=4

# Admin User (created on first run)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-this-strong-password
ADMIN_EMAIL=admin@yourdomain.com
